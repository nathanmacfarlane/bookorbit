# Database
DATABASE_URL=postgres://projectx:projectx@localhost:5432/projectx

# App
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Storage
BOOKS_PATH=/books

# SMTP (optional — if unset, self-service password reset is disabled)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
APP_URL=http://localhost:5173
