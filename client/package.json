{
  "name": "client",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:cov": "vitest --coverage",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "pnpm run lint:check",
    "lint:check": "run-s lint:oxlint:check lint:eslint:check",
    "lint:fix": "run-s lint:oxlint:fix lint:eslint:fix",
    "lint:oxlint:check": "oxlint src",
    "lint:oxlint:fix": "oxlint src --fix",
    "lint:eslint:check": "eslint src --cache",
    "lint:eslint:fix": "eslint src --fix --cache",
    "format": "prettier --write --experimental-cli src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@bookorbit/types": "workspace:*",
    "@tailwindcss/vite": "^4.2.4",
    "@types/howler": "^2.2.12",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.1",
    "driver.js": "^1.4.0",
    "echarts": "^6.0.0",
    "howler": "^2.2.4",
    "lucide-vue-next": "^1.0.0",
    "pdfjs-dist": "^5.6.205",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.6",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.33",
    "vue-draggable-plus": "^0.6.1",
    "vue-echarts": "8.1.0-beta.2",
    "vue-router": "^5.0.6",
    "vue-sonner": "^2.0.9",
    "vue-virtual-scroller": "^3.0.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/dompurify": "^3.2.0",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.61.0",
    "eslint-plugin-vue": "~10.9.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.61.0",
    "prettier": "3.8.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.10",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
